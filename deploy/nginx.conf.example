# =============================================================================
# Nginx reverse proxy block for RentFlow Agent API
# =============================================================================
# Save as /etc/nginx/sites-available/rentflow-api and symlink to sites-enabled.
# TLS handled by certbot — run `sudo certbot --nginx -d api.rentalho.com`
# after this is in place to provision the cert and have certbot rewrite the
# server block. Reload: `sudo nginx -t && sudo systemctl reload nginx`.
# =============================================================================

server {
    listen 80;
    listen [::]:80;
    server_name api.rentalho.com;

    # Certbot will replace this with a 301 to https after issuing the cert.
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name api.rentalho.com;

    # Certbot will manage these:
    # ssl_certificate     /etc/letsencrypt/live/api.rentalho.com/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/api.rentalho.com/privkey.pem;
    # include /etc/letsencrypt/options-ssl-nginx.conf;

    # Body size for media uploads (matches API limits)
    client_max_body_size 50M;

    # Hardening
    server_tokens off;
    add_header X-Frame-Options "DENY" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    location / {
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # WebSocket / streaming upgrades (future-proofing)
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        # Timeouts: tuned for Anthropic calls (Claude can take ~15-30s with thinking)
        proxy_connect_timeout 10s;
        proxy_send_timeout    60s;
        proxy_read_timeout    60s;
    }

    location /health {
        proxy_pass http://127.0.0.1:3001/health;
        access_log off;
    }

    access_log /var/log/nginx/rentflow-api.access.log;
    error_log  /var/log/nginx/rentflow-api.error.log;
}
