# =============================================================================
# RentFlow Agent - Environment Variables
# =============================================================================
# Copy to .env and fill in values for local development.
# Production values must come from a secret manager, not this file.
# =============================================================================

# -----------------------------
# Runtime
# -----------------------------
NODE_ENV="development"
PORT="3001"
LOG_LEVEL="info"

# -----------------------------
# Database (PostgreSQL)
# -----------------------------
DATABASE_URL="postgresql://rentflow:rentflow@localhost:5432/rentflow?schema=public"

# -----------------------------
# Redis (BullMQ + cache)
# -----------------------------
REDIS_URL="redis://localhost:6379"
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""

# -----------------------------
# Auth
# -----------------------------
JWT_SECRET="change-me-in-production-use-32-bytes-of-randomness"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# -----------------------------
# CORS / public origins
# -----------------------------
WEB_APP_URL="http://localhost:3000"
MOBILE_APP_URL="exp://localhost:8081"
ALLOWED_ORIGINS="http://localhost:3000,exp://localhost:8081"

# -----------------------------
# WhatsApp Business Cloud API
# -----------------------------
# Default RentFlow Agent business number (UAE).
# This is the public number used for click-to-chat links and Cloud API binding.
WHATSAPP_BUSINESS_PHONE_LOCAL="0585063316"
WHATSAPP_BUSINESS_PHONE_E164="+971585063316"
WHATSAPP_BUSINESS_WA_ME_BASE_URL="https://wa.me/971585063316"

# Cloud API credentials (leave blank for local mock; never commit real values)
WHATSAPP_CLOUD_API_PHONE_NUMBER_ID=""
WHATSAPP_CLOUD_API_BUSINESS_ACCOUNT_ID=""
WHATSAPP_CLOUD_API_ACCESS_TOKEN=""
WHATSAPP_WEBHOOK_VERIFY_TOKEN="local-dev-verify-token"
WHATSAPP_APP_SECRET=""

# Adapter selection: "mock" | "cloud"
WHATSAPP_ADAPTER="mock"

# Operator phone (E.164). When set, every new pending Suggestion is pushed to
# this number with Approve / Edit / Cancel buttons. The operator must opt in
# first by sending any message to the business number to open the 24h
# customer-service window.
OPERATOR_WHATSAPP_E164=""

# -----------------------------
# AI Provider
# -----------------------------
# Adapter: "mock" | "openai" | "anthropic"
AI_PROVIDER="mock"
AI_API_KEY=""
AI_MODEL="claude-sonnet-4-6"
AI_BASE_URL=""

# -----------------------------
# Object storage (S3-compatible / MinIO)
# -----------------------------
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="rentflow-media"
S3_ACCESS_KEY="rentflow"
S3_SECRET_KEY="rentflow-secret"
S3_FORCE_PATH_STYLE="true"
S3_PUBLIC_BASE_URL="http://localhost:9000/rentflow-media"

# -----------------------------
# Web app (Next.js)
# -----------------------------
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_APP_NAME="RentFlow Agent"

# -----------------------------
# Mobile app (Expo)
# -----------------------------
EXPO_PUBLIC_API_URL="http://localhost:3001"

# -----------------------------
# Tracking links / attribution
# -----------------------------
TRACKING_BASE_URL="http://localhost:3001/t"
SOURCE_CODE_PREFIX="RF"
POST_CODE_PREFIX="POST"
