{
  "name": "@rentflow/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "build": "echo 'Use EAS Build for native binaries'",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "update": "eas update",
    "update:preview": "eas update --branch preview",
    "update:prod": "eas update --branch production",
    "eas-build-post-install": "cd ../.. && pnpm --filter @rentflow/shared build"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@rentflow/shared": "workspace:*",
    "expo": "~54.0.0",
    "expo-constants": "~18.0.0",
    "expo-device": "~8.0.10",
    "expo-file-system": "^19.0.22",
    "expo-image-picker": "~17.0.0",
    "expo-linking": "~8.0.0",
    "expo-media-library": "^18.2.1",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.0",
    "expo-status-bar": "~3.0.0",
    "expo-updates": "~29.0.17",
    "nativewind": "^2.0.11",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "4.16.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/react": "~19.1.17",
    "babel-preset-expo": "^55.0.21",
    "tailwindcss": "3.3.2",
    "typescript": "^5.5.0"
  }
}
