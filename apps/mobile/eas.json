{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "ios": { "simulator": true },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://rentflow-api.rentalho.com"
      }
    },
    "production": {
      "android": { "buildType": "app-bundle" },
      "ios": {
        "buildConfiguration": "Release",
        "credentialsSource": "remote"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://rentflow-api.rentalho.com"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "casey911106@gmail.com",
        "appleTeamId": "RW3799QY9F"
      }
    }
  }
}
