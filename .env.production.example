# =============================================================================
# RentFlow Agent — PRODUCTION environment template
# =============================================================================
# Copy to .env on the production VPS (or set as env vars in your platform).
# Never commit the actual .env file. Rotate any credential that ends up in
# version control or chat logs.
# =============================================================================

# ---- Runtime ----------------------------------------------------------------
NODE_ENV="production"
PORT="3001"
LOG_LEVEL="info"
BOOTED_AT=""  # leave blank — set automatically at boot

# ---- Database (Supabase) ----------------------------------------------------
# Runtime — Transaction pooler (port 6543). Add ?pgbouncer=true so Prisma
# disables prepared statements (PgBouncer can't reuse them).
DATABASE_URL="postgresql://postgres.bysfcjswngunizyfingk:URL_ENCODED_PASSWORD@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Direct connection (port 5432) — required for migrations only. Migrations
# run via `prisma migrate deploy`, which runs schema-DDL the pooler can't.
DIRECT_URL="postgresql://postgres:URL_ENCODED_PASSWORD@db.bysfcjswngunizyfingk.supabase.co:5432/postgres"

# Special chars in the password must be URL-encoded:
#   @ -> %40    # -> %23    : -> %3A    / -> %2F    ? -> %3F    & -> %26

# ---- Redis (optional, only if BullMQ is added later) ------------------------
# REDIS_URL=""

# ---- Auth -------------------------------------------------------------------
JWT_SECRET="generate-32-bytes-of-random-here-with-openssl-rand-hex-32"
JWT_EXPIRES_IN="7d"

# ---- CORS / public origins --------------------------------------------------
WEB_APP_URL="https://app.rentalho.com"
ALLOWED_ORIGINS="https://app.rentalho.com"

# ---- WhatsApp Business Cloud API --------------------------------------------
WHATSAPP_BUSINESS_PHONE_LOCAL="0585063316"
WHATSAPP_BUSINESS_PHONE_E164="+971585063316"
WHATSAPP_BUSINESS_WA_ME_BASE_URL="https://wa.me/971585063316"
WHATSAPP_CLOUD_API_PHONE_NUMBER_ID="1099794413216989"
WHATSAPP_CLOUD_API_BUSINESS_ACCOUNT_ID="1715071569906398"
WHATSAPP_CLOUD_API_ACCESS_TOKEN="ROTATE_THIS_TOKEN_FROM_BUSINESS_FACEBOOK_COM"
WHATSAPP_WEBHOOK_VERIFY_TOKEN="generate-32-bytes-of-random-here"
WHATSAPP_APP_SECRET="ROTATE_THIS_FROM_DEVELOPERS_FACEBOOK_COM"
WHATSAPP_ADAPTER="cloud"

# ---- Operator phone (Capa 2 WhatsApp button notifications) ------------------
OPERATOR_WHATSAPP_E164="+971526608543"

# ---- AI Provider ------------------------------------------------------------
AI_PROVIDER="anthropic"
AI_API_KEY="sk-ant-api03-ROTATE_THIS_KEY"
AI_MODEL="claude-sonnet-4-6"

# ---- File storage (local on the VPS) ----------------------------------------
LOCAL_UPLOAD_DIR="/var/lib/rentflow/uploads"

# ---- Tracking links ---------------------------------------------------------
TRACKING_BASE_URL="https://api.rentalho.com/t"
SOURCE_CODE_PREFIX="RF"
POST_CODE_PREFIX="POST"

# ---- Error tracking (optional) ----------------------------------------------
# Sign up at https://sentry.io (free tier: 5K events/month). Create a Node
# project, copy its DSN here. When unset, Sentry init is a no-op.
SENTRY_DSN=""

# ---- Hostaway integration ---------------------------------------------------
# When set, the API runs a daily availability sync at 05:00 Asia/Dubai.
# Get values from Hostaway dashboard → Settings → Hostaway API.
HOSTAWAY_ACCOUNT_ID=""
HOSTAWAY_API_KEY=""
