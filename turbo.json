{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env", ".env.local"],
  "globalEnv": [
    "NODE_ENV",
    "DATABASE_URL",
    "REDIS_URL",
    "JWT_SECRET",
    "WHATSAPP_BUSINESS_PHONE_LOCAL",
    "WHATSAPP_BUSINESS_PHONE_E164",
    "WHATSAPP_BUSINESS_WA_ME_BASE_URL",
    "WHATSAPP_CLOUD_API_PHONE_NUMBER_ID",
    "WHATSAPP_CLOUD_API_BUSINESS_ACCOUNT_ID",
    "WHATSAPP_CLOUD_API_ACCESS_TOKEN",
    "WHATSAPP_WEBHOOK_VERIFY_TOKEN",
    "WHATSAPP_APP_SECRET",
    "AI_PROVIDER",
    "AI_API_KEY",
    "AI_MODEL",
    "S3_ENDPOINT",
    "S3_BUCKET",
    "S3_ACCESS_KEY",
    "S3_SECRET_KEY",
    "NEXT_PUBLIC_API_URL",
    "EXPO_PUBLIC_API_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "clean": {
      "cache": false
    }
  }
}
