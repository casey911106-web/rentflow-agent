// =============================================================================
// RentFlow Agent — Prisma schema
// Source of truth for the data model. All entities are tenant-scoped via
// `companyId`. UUID primary keys, UTC timestamps, soft delete where noted.
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Runtime URL — points at the pooler (PgBouncer) in production for Supabase.
  url       = env("DATABASE_URL")
  // Direct connection — used by `prisma migrate` and `prisma db push`. The
  // pooler can't run schema-DDL statements; the direct URL bypasses it.
  // Optional in local dev (Prisma falls back to DATABASE_URL when DIRECT_URL
  // is unset), required in any Supabase setup.
  directUrl = env("DIRECT_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserStatus {
  active
  invited
  suspended
  archived
}

enum RoleName {
  super_admin
  ops_manager
  field_agent
}

enum PropertyType {
  bed_space
  shared_room
  partition
  standard_room
  master_room
  studio
  one_bedroom
  two_bedroom
  three_bedroom
  villa
  other
}

enum PropertyStatus {
  draft
  available
  pending_owner_confirmation
  rented
  blocked
  unavailable
  archived
  needs_media
  needs_price_confirmation
  not_ready_to_post
}

enum LeadStatus {
  new
  contacted
  qualifying
  qualified
  options_sent
  viewing_requested
  viewing_scheduled
  viewing_completed
  negotiating
  won
  lost
  cold
  opted_out
}

enum LeadTemperature {
  hot
  warm
  cold
  unqualified
}

enum AttributionConfidence {
  high
  medium
  low
  none
}

enum ViewingStatus {
  requested
  confirmed
  assigned
  rescheduled
  cancelled
  no_show
  completed
  converted
  lost
}

enum PostPackageStatus {
  draft
  generated
  scheduled
  pending_approval
  approved
  published
  failed
  paused
  archived
}

/// What this PostPackage promotes. `property_listing` is the original use:
/// a Property in our inventory pushed to FB groups / WA groups so leads
/// open it. `channel_growth` is a different beast — the post promotes one
/// of our owned channels (Telegram, FB page, IG profile) so we acquire
/// followers there. Same round-robin pool, same placement+tracking flow,
/// different redirect target.
enum PostPackageKind {
  property_listing
  channel_growth
}

enum OwnerAvailabilityStatus {
  available
  unavailable
  rented
  blocked_until_date
  pending_response
  needs_clarification
}

enum ConversationMode {
  ai
  human_takeover
  paused
  closed
}

enum DealStatus {
  open
  negotiating
  won
  lost
  cancelled
}

enum CommissionStatus {
  expected
  invoiced
  partially_collected
  collected
  waived
  lost
}

enum PaymentStatus {
  pending
  partially_paid
  paid
  failed
  refunded
}

enum AgentAssignmentStatus {
  pending
  accepted
  declined
  completed
}

enum PropertyIssueType {
  unavailable_when_expected
  dirty
  access_problem
  price_changed
  owner_not_responding
  wrong_media
  client_complaint
  maintenance_issue
  other
}

enum MessageDirection {
  inbound
  outbound
}

enum MessageType {
  text
  image
  video
  document
  template
  system
  interactive
}

enum ChannelPlatform {
  facebook
  whatsapp
  instagram
  telegram
  referral
  direct
  other
}

enum ChannelKind {
  group
  page
  channel
  individual
  unknown
}

enum NotificationKind {
  info
  warning
  error
  success
  action_required
}

/// Type of a configurable property-detail question. Drives the input widget
/// rendered in the mobile form and the validation applied to answers.
///   text      → free-text (e.g. nationalities)
///   number    → integer (e.g. occupants count)
///   boolean   → yes/no toggle (e.g. has daily cleaning)
///   enum      → single-choice from `options[]` (e.g. bathroom: private | shared)
///   multi_enum→ multi-choice from `options[]` (e.g. services included)
enum PropertyDetailQuestionType {
  text
  number
  boolean
  enum
  multi_enum
}

/// Lifecycle of a PropertyDetailsCheck task assigned to a field agent.
///   pending  → assigned, agent has not submitted yet
///   filled   → agent submitted answers (terminal)
///   expired  → TTL elapsed without submission (terminal; cron re-assigns)
///   cancelled→ property no longer needs details (terminal; e.g. archived)
enum PropertyDetailsCheckStatus {
  pending
  filled
  expired
  cancelled
}

enum AutomationTriggerType {
  schedule
  event
  manual
}

enum ScoreKind {
  quality
  readiness
}

// =============================================================================
// TENANCY + IDENTITY
// =============================================================================

model Company {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  countryCode String    @default("AE")
  timezone    String    @default("Asia/Dubai")
  currency    String    @default("AED")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  users                   User[]
  properties              Property[]
  owners                  Owner[]
  leads                   Lead[]
  campaigns               Campaign[]
  postPackages            PostPackage[]
  postPlacements          PostPlacement[]
  postAssignments         PostAssignment[]
  postChannels            PostChannel[]
  trackingLinks           TrackingLink[]
  viewings                Viewing[]
  scheduleTokens          ViewingScheduleToken[]
  costEntries             CostEntry[]
  costSubscriptions       CostSubscription[]
  deals                   Deal[]
  commissionSplits        CommissionSplit[]
  notifications           Notification[]
  automationRules         AutomationRule[]
  appSettings             AppSetting[]
  integrationTokens       IntegrationToken[]
  webhookLogs             WebhookLog[]
  auditLogs               AuditLog[]
  fileUploads             FileUpload[]
  whatsAppConversations   WhatsAppConversation[]
  whatsAppMessages        WhatsAppMessage[]
  aiPromptTemplates       AIPromptTemplate[]
  aiAgentSessions         AIAgentSession[]
  ownerAvailabilityChecks OwnerAvailabilityCheck[]
  propertyDetailQuestions PropertyDetailQuestion[]
  propertyDetailsChecks   PropertyDetailsCheck[]
  leadMessages            LeadMessage[]
  leadSources             LeadSource[]
  fieldAgents             FieldAgent[]
  suggestions             Suggestion[]
  trainingExamples        TrainingExample[]
  scheduledChannelPosts   ScheduledChannelPost[]

  @@index([slug])
}

model User {
  id             String     @id @default(uuid())
  companyId      String
  company        Company    @relation(fields: [companyId], references: [id])
  email          String
  passwordHash   String
  fullName       String
  phoneE164      String?
  roles          RoleName[] @default([ops_manager])
  status         UserStatus @default(active)
  lastLoginAt    DateTime?
  /// Expo push tokens for this user's devices. One user can be logged in
  /// on multiple devices (phone + tablet) so we keep an array. Tokens get
  /// pushed to /me/push-token on login + on app launch; stale ones drift
  /// out via the periodic prune task.
  expoPushTokens String[]   @default([])
  /// Partner agent — sources properties from external WhatsApp groups.
  /// When true, inbound WhatsApp from this user's phone with a `/property`
  /// keyword routes to the IngestionService instead of the lead flow.
  /// Their commission (50% of RentFlow's commission per closed deal) is
  /// tracked on Deal.partnerUserId / partnerOwesUsAed.
  isPartner      Boolean    @default(false)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  deletedAt      DateTime?

  fieldAgent          FieldAgent?
  notifications       Notification[]
  publishedPackages   PostPackage[]    @relation("PublishedByUser")
  approvedPackages    PostPackage[]    @relation("ApprovedByUser")
  postPlacements      PostPlacement[]  @relation("PostPlacementPublisher")
  postAssignments     PostAssignment[] @relation("PostAssignmentAssignee")
  availabilityChecks  OwnerAvailabilityCheck[] @relation("AvailabilityCheckAssignee")
  detailsChecks       PropertyDetailsCheck[]   @relation("PropertyDetailsCheckAssignee")
  commissionSplits    CommissionSplit[] @relation("CommissionSplitRecipient")
  auditLogs           AuditLog[]
  fileUploads         FileUpload[]
  decidedSuggestions  Suggestion[]     @relation("SuggestionDecidedBy")
  submittedProperties Property[]       @relation("PropertySubmittedBy")
  assignedProperties  Property[]       @relation("PropertyAssignedAgent")
  partnerDeals        Deal[]           @relation("DealPartner")
  scheduledChannelPosts ScheduledChannelPost[] @relation("ScheduledChannelPostCreator")

  @@unique([companyId, email])
  @@index([companyId])
}

model Permission {
  id          String   @id @default(uuid())
  key         String   @unique
  description String
  createdAt   DateTime @default(now())
}

model AppSetting {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  key       String
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, key])
  @@index([companyId])
}

model IntegrationToken {
  id             String    @id @default(uuid())
  companyId      String
  company        Company   @relation(fields: [companyId], references: [id])
  provider       String // "whatsapp" | "openai" | "anthropic" | "s3" | ...
  label          String?
  encryptedValue String // KMS-wrapped
  metadata       Json?
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([companyId, provider, label])
  @@index([companyId])
}

model WebhookLog {
  id          String   @id @default(uuid())
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id])
  source      String // "whatsapp" | "stripe" | ...
  signatureOk Boolean
  rawBody     Json
  headers     Json
  receivedAt  DateTime @default(now())

  @@index([source, receivedAt])
  @@index([companyId])
}

model AuditLog {
  id          String    @id @default(uuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id])
  actorUserId String?
  actor       User?     @relation(fields: [actorUserId], references: [id])
  actorRole   RoleName?
  entityType  String
  entityId    String
  action      String
  diff        Json?
  ip          String?
  userAgent   String?
  createdAt   DateTime  @default(now())

  @@index([companyId, createdAt])
  @@index([entityType, entityId])
}

model FileUpload {
  id              String   @id @default(uuid())
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id])
  uploadedById    String?
  uploadedBy      User?    @relation(fields: [uploadedById], references: [id])
  bucket          String
  s3Key           String
  mimeType        String
  sizeBytes       Int
  originalName    String?
  ownerEntityType String? // "Property" | "Viewing" | "PropertyIssue" | ...
  ownerEntityId   String?
  createdAt       DateTime @default(now())

  propertyMedia PropertyMedia[]

  @@index([companyId])
  @@index([ownerEntityType, ownerEntityId])
}

// =============================================================================
// OWNERS
// =============================================================================

model Owner {
  id              String    @id @default(uuid())
  companyId       String
  company         Company   @relation(fields: [companyId], references: [id])
  fullName        String
  phoneE164       String
  email           String?
  notes           String?
  trustScore      Int       @default(50)
  responseRate    Float     @default(0)
  lastContactedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  properties         Property[]
  ownerMessages      OwnerMessage[]
  availabilityChecks OwnerAvailabilityCheck[]
  scoreSnapshots     OwnerScoreSnapshot[]

  @@unique([companyId, phoneE164])
  @@index([companyId])
}

model OwnerMessage {
  id        String           @id @default(uuid())
  ownerId   String
  owner     Owner            @relation(fields: [ownerId], references: [id])
  direction MessageDirection
  type      MessageType      @default(text)
  body      String
  metadata  Json?
  createdAt DateTime         @default(now())

  @@index([ownerId, createdAt])
}

model OwnerAvailabilityCheck {
  id          String                  @id @default(uuid())
  companyId   String
  company     Company                 @relation(fields: [companyId], references: [id])
  ownerId     String
  owner       Owner                   @relation(fields: [ownerId], references: [id])
  propertyId  String
  property    Property                @relation(fields: [propertyId], references: [id])
  status      OwnerAvailabilityStatus @default(pending_response)
  askedAt     DateTime                @default(now())
  repliedAt   DateTime?
  parsedReply Json?
  rawReply    String?
  nextCheckAt DateTime?

  // Field-agent assignment (round-robin sweep every 12h, 24h TTL)
  assigneeUserId        String?
  assignee              User?     @relation("AvailabilityCheckAssignee", fields: [assigneeUserId], references: [id])
  assignedAt            DateTime?
  expiresAt             DateTime?
  fulfilledAt           DateTime?
  reportedAvailableFrom DateTime?
  reportedNotes         String?

  @@index([companyId, askedAt])
  @@index([ownerId])
  @@index([propertyId])
  @@index([assigneeUserId, status])
  @@index([status, expiresAt])
}

model OwnerScoreSnapshot {
  id        String   @id @default(uuid())
  ownerId   String
  owner     Owner    @relation(fields: [ownerId], references: [id])
  score     Int
  factors   Json
  createdAt DateTime @default(now())

  @@index([ownerId, createdAt])
}

// =============================================================================
// PROPERTIES
// =============================================================================

model Property {
  id                      String         @id @default(uuid())
  companyId               String
  company                 Company        @relation(fields: [companyId], references: [id])
  ownerId                 String?
  owner                   Owner?         @relation(fields: [ownerId], references: [id])
  code                    String // permanent code, e.g. RF-001
  name                    String
  type                    PropertyType
  status                  PropertyStatus @default(draft)
  area                    String?
  addressLine             String?
  latitude                Float?
  longitude               Float?
  priceAed                Decimal?       @db.Decimal(12, 2)
  depositAed              Decimal?       @db.Decimal(12, 2)
  commissionPolicy        String?
  description             String?
  occupancyMax            Int?
  rentalMinMonths         Int?
  amenities               Json?
  /// Free-form answers to PropertyDetailQuestion catalogue, keyed by the
  /// question's `key` (e.g. { "occupants_count": 3, "bathroom": "shared",
  /// "nationalities": "Pakistani, Indian", "daily_cleaning": false }). Used
  /// by the WhatsApp AI agent so it can answer guest FAQs without escalating
  /// to a human. Filled by field agents via the mobile form.
  details                 Json?
  /// Stamped when EVERY active required question has a non-empty answer in
  /// `details`. The PropertyDetailsCheck scheduler skips properties whose
  /// stamp is fresher than the staleness window.
  detailsCompletedAt      DateTime?
  viewingAccess           String?
  moveInDate              DateTime?
  rentedUntil             DateTime?
  priceConfirmedAt        DateTime?
  availabilityConfirmedAt DateTime?
  qualityScore            Int            @default(50)
  readinessScore          Int            @default(0)
  /// Set when this property was sourced via the partner-WhatsApp ingestion
  /// flow (User.isPartner = true sends `/property`). Drives:
  /// - 'Submitted by partner' badge in /properties
  /// - Commission split — 50% of commissionAed gets stamped on the Deal as
  ///   partnerOwesUsAed when the deal closes.
  submittedByUserId       String?
  submittedBy             User?          @relation("PropertySubmittedBy", fields: [submittedByUserId], references: [id])
  /// Pre-assigned field-agent who handles every viewing for this listing.
  /// Set at ingestion time (parsed from "Agente: <name>" in the partner
  /// submission). The scheduler defers to this assignment over the
  /// usual round-robin pick.
  assignedFieldAgentId    String?
  assignedFieldAgent      User?          @relation("PropertyAssignedAgent", fields: [assignedFieldAgentId], references: [id])
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  deletedAt               DateTime?

  media                   PropertyMedia[]
  availabilityBlocks      PropertyAvailabilityBlock[]
  calendarEvents          PropertyCalendarEvent[]
  issues                  PropertyIssue[]
  scoreSnapshots          PropertyScoreSnapshot[]
  postPackages            PostPackage[]
  leads                   Lead[]
  viewings                Viewing[]
  deals                   Deal[]
  ownerAvailabilityChecks OwnerAvailabilityCheck[]
  detailsChecks           PropertyDetailsCheck[]
  scheduleTokens          ViewingScheduleToken[]

  @@unique([companyId, code])
  @@index([companyId, status])
  @@index([ownerId])
  @@index([submittedByUserId])
  @@index([assignedFieldAgentId])
}

model PropertyMedia {
  id           String     @id @default(uuid())
  propertyId   String
  property     Property   @relation(fields: [propertyId], references: [id])
  fileUploadId String
  file         FileUpload @relation(fields: [fileUploadId], references: [id])
  kind         String // "photo" | "video" | "floorplan"
  caption      String?
  position     Int        @default(0)
  createdAt    DateTime   @default(now())

  @@index([propertyId])
}

model PropertyAvailabilityBlock {
  id         String   @id @default(uuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])
  startsAt   DateTime
  endsAt     DateTime
  reason     String
  createdAt  DateTime @default(now())

  @@index([propertyId, startsAt])
}

model PropertyCalendarEvent {
  id         String   @id @default(uuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])
  kind       String // "rented" | "blocked" | "viewing" | "maintenance"
  startsAt   DateTime
  endsAt     DateTime
  refType    String? // "Viewing" | "Deal" | etc.
  refId      String?
  notes      String?
  createdAt  DateTime @default(now())

  @@index([propertyId, startsAt])
}

model PropertyIssue {
  id           String            @id @default(uuid())
  propertyId   String
  property     Property          @relation(fields: [propertyId], references: [id])
  reportedById String?
  type         PropertyIssueType
  description  String
  resolvedAt   DateTime?
  metadata     Json?
  createdAt    DateTime          @default(now())

  @@index([propertyId, createdAt])
}

model PropertyScoreSnapshot {
  id         String    @id @default(uuid())
  propertyId String
  property   Property  @relation(fields: [propertyId], references: [id])
  kind       ScoreKind
  score      Int
  factors    Json
  createdAt  DateTime  @default(now())

  @@index([propertyId, kind, createdAt])
}

/// Admin-configurable question that the field agent must answer about a
/// property. Lives outside the Property model so ops can add new basics
/// without a schema migration (e.g. "Allows pets?", "WiFi password type?").
/// Mobile renders the form dynamically from the active rows.
///
/// `key` is the stable identifier stored as the JSON key on Property.details.
/// `position` controls display order in the mobile form.
/// `options` is required for type=enum/multi_enum (string[] of allowed values).
model PropertyDetailQuestion {
  id           String                     @id @default(uuid())
  companyId    String
  company      Company                    @relation(fields: [companyId], references: [id])
  key          String
  label        String
  helperText   String?
  type         PropertyDetailQuestionType
  options      Json?
  isRequired   Boolean                    @default(true)
  isActive     Boolean                    @default(true)
  position     Int                        @default(0)
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt
  deletedAt    DateTime?

  @@unique([companyId, key])
  @@index([companyId, isActive, position])
}

/// Task assigned to a field agent: gather the basic property facts (the
/// `details` JSON on Property) by asking the owner. Created when a property
/// is published via fast-posting and details are missing/stale. Re-assigned
/// by the scheduler every cycle until filled, so the publisher who just
/// posted gets first crack but the task rotates if they don't act.
///
/// Lifecycle mirrors OwnerAvailabilityCheck: pending → filled (terminal) or
/// expired (cron reassigns).
model PropertyDetailsCheck {
  id             String                     @id @default(uuid())
  companyId      String
  company        Company                    @relation(fields: [companyId], references: [id])
  propertyId     String
  property       Property                   @relation(fields: [propertyId], references: [id])
  status         PropertyDetailsCheckStatus @default(pending)
  assigneeUserId String?
  assignee       User?                      @relation("PropertyDetailsCheckAssignee", fields: [assigneeUserId], references: [id])
  assignedAt     DateTime                   @default(now())
  expiresAt      DateTime
  fulfilledAt    DateTime?
  /// Snapshot of the answers submitted in this attempt (for audit/rollback).
  /// The current authoritative answers live on Property.details.
  submittedAnswers Json?

  @@index([companyId, status])
  @@index([propertyId, status])
  @@index([assigneeUserId, status])
  @@index([status, expiresAt])
}

// =============================================================================
// FIELD AGENTS
// =============================================================================

model FieldAgent {
  id               String   @id @default(uuid())
  companyId        String
  company          Company  @relation(fields: [companyId], references: [id])
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id])
  preferredAreas   Json?
  performanceScore Int      @default(50)
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  availability       AgentAvailability[]
  performanceHistory AgentPerformanceSnapshot[]
  viewings           Viewing[]
  deals              Deal[]

  @@index([companyId])
}

model AgentAvailability {
  id           String     @id @default(uuid())
  fieldAgentId String
  fieldAgent   FieldAgent @relation(fields: [fieldAgentId], references: [id])
  startsAt     DateTime
  endsAt       DateTime
  isAvailable  Boolean    @default(true)
  notes        String?
  createdAt    DateTime   @default(now())

  @@index([fieldAgentId, startsAt])
}

model AgentPerformanceSnapshot {
  id           String     @id @default(uuid())
  fieldAgentId String
  fieldAgent   FieldAgent @relation(fields: [fieldAgentId], references: [id])
  score        Int
  factors      Json
  createdAt    DateTime   @default(now())

  @@index([fieldAgentId, createdAt])
}

// =============================================================================
// LEADS + CONVERSATIONS
// =============================================================================

model Lead {
  id                     String                @id @default(uuid())
  companyId              String
  company                Company               @relation(fields: [companyId], references: [id])
  propertyId             String?
  property               Property?             @relation(fields: [propertyId], references: [id])
  postPackageId          String?
  postPackage            PostPackage?          @relation(fields: [postPackageId], references: [id])
  trackingLinkId         String?
  trackingLink           TrackingLink?         @relation(fields: [trackingLinkId], references: [id])
  /// Set when the lead arrived through a placement tracking slug. Lets us
  /// answer "which Telegram post produced this lead?" without going through
  /// the package-level TrackingLink (which is shared across all placements).
  attributionPlacementId String?
  attributionPlacement   PostPlacement?        @relation("PostPlacementAttribution", fields: [attributionPlacementId], references: [id])
  /// Free-form bucket label (e.g. "telegram_en", "telegram_es", "ig_reel") —
  /// what we sort by in the analytics dashboard.
  attributionSource      String?
  campaignId             String?
  campaign               Campaign?             @relation(fields: [campaignId], references: [id])
  sourceId               String?               @unique
  source                 LeadSource?           @relation(fields: [sourceId], references: [id])
  whatsappConversationId String?               @unique
  whatsappConversation   WhatsAppConversation? @relation(fields: [whatsappConversationId], references: [id])

  fullName              String?
  phoneE164             String
  status                LeadStatus            @default(new)
  temperature           LeadTemperature       @default(unqualified)
  qualificationScore    Int                   @default(0)
  attributionConfidence AttributionConfidence @default(none)

  budgetAed            Decimal?  @db.Decimal(12, 2)
  preferredArea        String?
  peopleCount          Int?
  moveInDate           DateTime?
  rentalDurationMonths Int?

  firstSeenAt       DateTime  @default(now())
  lastInteractionAt DateTime?
  lastFollowUpAt    DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  messages       LeadMessage[]
  viewings       Viewing[]
  deal           Deal?
  aiSessions     AIAgentSession[]
  suggestions    Suggestion[]
  scheduleTokens ViewingScheduleToken[]

  @@index([companyId, status])
  @@index([companyId, temperature])
  @@index([companyId, createdAt])
  @@index([propertyId])
  @@index([postPackageId])
  @@index([attributionPlacementId])
  @@index([companyId, attributionSource])
  @@index([phoneE164])
}

model LeadSource {
  id            String          @id @default(uuid())
  companyId     String
  company       Company         @relation(fields: [companyId], references: [id])
  channel       ChannelPlatform
  channelKind   ChannelKind?
  channelName   String?
  campaignName  String?
  postCode      String?
  sourceCode    String?
  groupOrPage   String?
  publishedById String?
  rawText       String?
  capturedAt    DateTime        @default(now())

  lead Lead?

  @@index([companyId, channel])
}

model LeadMessage {
  id        String           @id @default(uuid())
  companyId String
  company   Company          @relation(fields: [companyId], references: [id])
  leadId    String
  lead      Lead             @relation(fields: [leadId], references: [id])
  direction MessageDirection
  channel   String // "whatsapp" | "internal_note" | "manual_call"
  body      String
  metadata  Json?
  createdAt DateTime         @default(now())

  @@index([leadId, createdAt])
}

model WhatsAppConversation {
  id             String           @id @default(uuid())
  companyId      String
  company        Company          @relation(fields: [companyId], references: [id])
  leadPhoneE164  String
  ownerPhoneE164 String? // if conversation is owner-side
  mode           ConversationMode @default(ai)
  lastInboundAt  DateTime?
  lastOutboundAt DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  messages    WhatsAppMessage[]
  lead        Lead?
  aiSessions  AIAgentSession[]
  suggestions Suggestion[]

  @@index([companyId, leadPhoneE164])
}

model WhatsAppMessage {
  id             String               @id @default(uuid())
  companyId      String
  company        Company              @relation(fields: [companyId], references: [id])
  conversationId String
  conversation   WhatsAppConversation @relation(fields: [conversationId], references: [id])
  externalId     String?              @unique // Cloud API message ID
  direction      MessageDirection
  type           MessageType          @default(text)
  body           String?
  mediaUrl       String?
  templateName   String?
  templateVars   Json?
  providerStatus String? // "sent" | "delivered" | "read" | "failed" | "mock_sent"
  providerError  String?
  metadata       Json?
  createdAt      DateTime             @default(now())

  @@index([conversationId, createdAt])
}

model AIAgentSession {
  id             String                @id @default(uuid())
  companyId      String
  company        Company               @relation(fields: [companyId], references: [id])
  leadId         String?
  lead           Lead?                 @relation(fields: [leadId], references: [id])
  conversationId String?
  conversation   WhatsAppConversation? @relation(fields: [conversationId], references: [id])
  machine        String // "lead" | "owner" | "feedback"
  state          String
  contextJson    Json
  startedAt      DateTime              @default(now())
  endedAt        DateTime?

  @@index([companyId, machine, state])
  @@index([leadId])
  @@index([conversationId])
}

model AIPromptTemplate {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  machine   String // "lead" | "owner" | "feedback" | "post_caption_short" | ...
  state     String?
  version   Int      @default(1)
  template  String
  variables Json? // declared variables for documentation/validation
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, machine, state, version])
  @@index([companyId, machine])
}

// =============================================================================
// POSTING + ATTRIBUTION
// =============================================================================

model Campaign {
  id        String    @id @default(uuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id])
  name      String
  goal      String?
  startsAt  DateTime?
  endsAt    DateTime?
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  postPackages PostPackage[]
  leads        Lead[]

  @@index([companyId])
}

model PostChannel {
  id         String          @id @default(uuid())
  companyId  String
  company    Company         @relation(fields: [companyId], references: [id])
  name       String
  platform   ChannelPlatform
  kind       ChannelKind     @default(unknown)
  notes      String?
  active     Boolean         @default(true)
  /// External provider ID — e.g. Telegram chat_id, Facebook page_id, IG business_id.
  /// Required when `automated = true`.
  externalId String?
  /// True when we own the channel and the bot posts automatically. False for
  /// external places where field agents post manually (the original Fast
  /// Posting use case).
  automated  Boolean         @default(false)
  createdAt  DateTime        @default(now())

  postPackages PostPackage[]
  scheduledPosts ScheduledChannelPost[]

  @@unique([companyId, platform, name])
  @@index([companyId])
}

model PostPackage {
  id         String       @id @default(uuid())
  companyId  String
  company    Company      @relation(fields: [companyId], references: [id])
  propertyId String?
  property   Property?    @relation(fields: [propertyId], references: [id])
  campaignId String?
  campaign   Campaign?    @relation(fields: [campaignId], references: [id])
  channelId  String?
  channel    PostChannel? @relation(fields: [channelId], references: [id])

  /// Discriminator. `property_listing` packages link to a Property and the
  /// tracking link redirects to the marketplace. `channel_growth` packages
  /// have no Property and the tracking link redirects directly to the
  /// channel/page join URL we're trying to grow.
  kind PostPackageKind @default(property_listing)

  status           PostPackageStatus @default(draft)
  title            String?
  shortCaption     String?
  longCaption      String?
  whatsappCaption  String?
  facebookCaption  String?
  priceLine        String?
  availabilityLine String?
  features         Json?

  /// Channel-growth only. Where we send users when they click the tracking
  /// link — e.g. https://t.me/rentflow_dubai or https://fb.com/rentflow.
  growthTargetUrl   String?
  /// Display label for ops/agents — e.g. "Telegram channel", "FB page".
  growthTargetLabel String?
  /// Categorises growth posts in the leaderboard / filters. Free-form:
  /// 'telegram' | 'facebook_page' | 'instagram' | 'whatsapp_community' | 'other'.
  growthTargetKind  String?

  channelName   String?
  publishedUrl  String?
  publishedById String?
  publishedBy   User?     @relation("PublishedByUser", fields: [publishedById], references: [id])
  publishedAt   DateTime?
  approvedById  String?
  approvedBy    User?     @relation("ApprovedByUser", fields: [approvedById], references: [id])
  approvedAt    DateTime?
  pausedAt      DateTime?
  archivedAt    DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  trackingLink TrackingLink?
  leads        Lead[]
  placements   PostPlacement[]
  assignments  PostAssignment[]
  scheduledPosts ScheduledChannelPost[]

  @@index([companyId, status])
  @@index([propertyId])
}

/// Queued auto-publish jobs to owned channels (Telegram/IG/FB page) that ops
/// scheduled for a future time. A cron picks up `status='pending'` rows
/// where `scheduledFor <= now` and fires the same auto-publish path the
/// "Publish now" button uses. The resulting PostPlacement is linked back
/// via `placementId` for audit.
model ScheduledChannelPost {
  id            String      @id @default(uuid())
  companyId     String
  company       Company     @relation(fields: [companyId], references: [id])
  postPackageId String
  postPackage   PostPackage @relation(fields: [postPackageId], references: [id])
  channelId     String
  channel       PostChannel @relation(fields: [channelId], references: [id])
  caption       String
  /// UTC. Frontend converts Dubai-local input (UTC+4) to UTC before send.
  scheduledFor  DateTime
  /// pending | done | failed | cancelled
  status        String      @default("pending")
  attemptedAt   DateTime?
  placementId   String?
  errorMessage  String?
  createdById   String?
  createdBy     User?       @relation("ScheduledChannelPostCreator", fields: [createdById], references: [id])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([companyId, status, scheduledFor])
  @@index([postPackageId])
}

/// One row per actual external publication of a PostPackage. Publishers
/// (ops_managers + field_agents) record each place they posted the listing
/// so we can measure effort, total reach, and per-channel performance.
model PostPlacement {
  id              String      @id @default(uuid())
  companyId       String
  company         Company     @relation(fields: [companyId], references: [id])
  postPackageId   String
  postPackage     PostPackage @relation(fields: [postPackageId], references: [id])
  publisherUserId String
  publisher       User        @relation("PostPlacementPublisher", fields: [publisherUserId], references: [id])

  channelName String? // "Dubai Marina FB Group", "PropertyFinder.ae". Null while in draft (slug pre-generated, agent hasn't confirmed where they posted yet).
  channelKind String? // facebook_group | classified | telegram | whatsapp_group | instagram | other
  externalUrl String? // direct link to the live post if shareable
  groupSize   Int? // estimated audience reach (group members, page followers)
  notes       String?
  /// When the agent confirmed where they posted this slug. Null = draft
  /// (slug copied to clipboard, agent hasn't come back to confirm yet).
  /// Drafts don't count toward the 3-placement minimum and don't trigger
  /// the package's published-status bump — only confirmed placements do.
  confirmedAt DateTime?

  /// True when posted by an automated adapter (bot) vs. a human field agent.
  automated      Boolean   @default(false)
  /// IG carousel variant index used for this placement (0..3) — rotates per
  /// publish so consecutive auto-posts for the same package don't look the
  /// same. Null on non-IG placements.
  carouselVariant Int?
  /// Caption/body that was actually published — kept here so we can audit
  /// what the lead saw and re-post the exact text if something needs editing.
  caption        String?
  /// Provider-side post ID — e.g. Telegram message_id, IG media_id. Lets us
  /// edit/delete the published post or fetch its metrics later.
  externalPostId String?
  /// Short unique slug stamped onto the marketplace tracking link
  /// (`/p/<code>?s=<slug>`). Each click increments `clicks` and the
  /// resulting lead is attributed to this placement.
  trackingSlug   String?   @unique
  clicks         Int       @default(0)
  lastClickAt    DateTime?

  publishedAt DateTime  @default(now())
  removedAt   DateTime?

  attributedLeads Lead[] @relation("PostPlacementAttribution")

  @@index([companyId, postPackageId])
  @@index([publisherUserId, publishedAt])
}

/// MVP cost-tracking ledger. Every paid action (Anthropic API call, Meta
/// WhatsApp template message, fixed subscription pro-rata) gets one row so
/// the admin can see total burn vs. revenue and spot anomalies fast.
model CostEntry {
  id             String            @id @default(uuid())
  companyId      String
  company        Company           @relation(fields: [companyId], references: [id])
  kind           String // anthropic_api | meta_whatsapp | fixed_subscription | fixed_one_off | vps | other
  label          String // human-readable: "Anthropic Sonnet 4.6 — 2026-05-08", "Virgin Mobile WA line — May 2026"
  amountAed      Decimal           @db.Decimal(12, 2)
  amountUsd      Decimal?          @db.Decimal(12, 2) // when source quotes USD
  subscriptionId String?
  subscription   CostSubscription? @relation(fields: [subscriptionId], references: [id])
  sourceType     String? // 'suggestion' | 'whatsapp_message' | 'subscription' | 'manual'
  metadata       Json? // {tokens: {...}, model, count, ...}
  incurredAt     DateTime          @default(now())
  createdAt      DateTime          @default(now())

  @@index([companyId, kind, incurredAt])
  @@index([subscriptionId])
}

/// Recurring fixed costs (monthly SIM lines, yearly developer fees, VPS, etc.).
/// A daily cron creates a pro-rata CostEntry from each active subscription so
/// the dashboard shows accrued burn smoothly instead of big monthly steps.
model CostSubscription {
  id        String    @id @default(uuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id])
  label     String
  kind      String // 'fixed_subscription' typically; categorises in UI
  amountAed Decimal   @db.Decimal(12, 2)
  cadence   String // 'monthly' | 'yearly'
  startsAt  DateTime
  endsAt    DateTime?
  active    Boolean   @default(true)
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  entries CostEntry[]

  @@index([companyId, active])
}

/// One-shot signed-style token issued when the AI agent or operator wants
/// to send the lead a self-service viewing scheduler link. Validated on
/// the public scheduler endpoint to authorise booking or rescheduling.
/// Either bookingFor a fresh viewing, or attached to an existing viewingId
/// for reschedule.
model ViewingScheduleToken {
  id         String    @id @default(uuid())
  companyId  String
  company    Company   @relation(fields: [companyId], references: [id])
  leadId     String
  lead       Lead      @relation(fields: [leadId], references: [id])
  propertyId String
  property   Property  @relation(fields: [propertyId], references: [id])
  viewingId  String? // set for reschedule tokens
  viewing    Viewing?  @relation(fields: [viewingId], references: [id])
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([companyId, leadId])
  @@index([viewingId])
}

/// Round-robin assignments: every hour the scheduler picks the next eligible
/// publisher and creates an Assignment row for each active PostPackage. The
/// publisher fulfills it by adding PostPlacement rows. Assignment closes
/// when at least one placement is logged or after 24h (whichever first).
model PostAssignment {
  id             String      @id @default(uuid())
  companyId      String
  company        Company     @relation(fields: [companyId], references: [id])
  postPackageId  String
  postPackage    PostPackage @relation(fields: [postPackageId], references: [id])
  assigneeUserId String
  assignee       User        @relation("PostAssignmentAssignee", fields: [assigneeUserId], references: [id])

  status      String    @default("pending") // pending | fulfilled | expired
  assignedAt  DateTime  @default(now())
  fulfilledAt DateTime?
  expiresAt   DateTime // assignedAt + 24h

  @@index([companyId, status])
  @@index([assigneeUserId, status])
  @@index([postPackageId, status])
}

model TrackingLink {
  id            String      @id @default(uuid())
  companyId     String
  company       Company     @relation(fields: [companyId], references: [id])
  postPackageId String      @unique
  postPackage   PostPackage @relation(fields: [postPackageId], references: [id])
  sourceCode    String      @unique
  postCode      String      @unique
  shortUrl      String
  whatsappUrl   String
  clicks        Int         @default(0)
  lastClickAt   DateTime?
  createdAt     DateTime    @default(now())

  leads Lead[]

  @@index([companyId])
}

// =============================================================================
// VIEWINGS, DEALS, MONEY
// =============================================================================

model Viewing {
  id           String      @id @default(uuid())
  companyId    String
  company      Company     @relation(fields: [companyId], references: [id])
  leadId       String
  lead         Lead        @relation(fields: [leadId], references: [id])
  propertyId   String
  property     Property    @relation(fields: [propertyId], references: [id])
  fieldAgentId String?
  fieldAgent   FieldAgent? @relation(fields: [fieldAgentId], references: [id])

  status           ViewingStatus         @default(requested)
  assignmentStatus AgentAssignmentStatus @default(pending)
  scheduledAt      DateTime
  durationMinutes  Int                   @default(30)
  arrivedAt        DateTime?
  completedAt      DateTime?
  outcomeNotes     String?
  cancelReason     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  feedback       ViewingFeedback?
  scheduleTokens ViewingScheduleToken[]

  @@index([companyId, scheduledAt])
  @@index([companyId, status])
  @@index([fieldAgentId, scheduledAt])
  @@index([leadId])
}

model ViewingFeedback {
  id            String   @id @default(uuid())
  viewingId     String   @unique
  viewing       Viewing  @relation(fields: [viewingId], references: [id])
  rating        Int? // 1-5
  comments      String?
  bookingIntent String? // "yes" | "maybe" | "no"
  raisedIssues  Json?
  createdAt     DateTime @default(now())
}

model Deal {
  id           String      @id @default(uuid())
  companyId    String
  company      Company     @relation(fields: [companyId], references: [id])
  leadId       String      @unique
  lead         Lead        @relation(fields: [leadId], references: [id])
  propertyId   String
  property     Property    @relation(fields: [propertyId], references: [id])
  fieldAgentId String?
  fieldAgent   FieldAgent? @relation(fields: [fieldAgentId], references: [id])

  status               DealStatus @default(open)
  rentAmount           Decimal?   @db.Decimal(12, 2)
  depositAmount        Decimal?   @db.Decimal(12, 2)
  commissionAmount     Decimal?   @db.Decimal(12, 2)
  commissionPaidBy     String? // "tenant" | "owner" | "split"
  moveInDate           DateTime?
  rentalDurationMonths Int?
  closedAt             DateTime?
  lostReason           String?
  internalNotes        String?

  /// Set when the underlying Property was sourced by a partner agent
  /// (Property.submittedByUserId). The partner collects the full commission
  /// from the owner; we then collect 50% of that back from them.
  /// This field tracks who that partner is for AR purposes.
  partnerUserId    String?
  partnerUser      User?     @relation("DealPartner", fields: [partnerUserId], references: [id])
  /// Amount the partner OWES RentFlow on this deal once they collect.
  /// Computed at deal close: commissionAmount * 0.5 by default.
  partnerOwesUsAed Decimal?  @db.Decimal(12, 2)
  /// Set when the partner has paid us their share. Until then, the amount
  /// shows up in /admin/costs as 'Partner receivables (AR)'.
  partnerSettledAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  commission Commission?
  splits     CommissionSplit[]

  @@index([companyId, status])
  @@index([propertyId])
  @@index([partnerUserId, partnerSettledAt])
}

/// One row per recipient of the deal's commission. Platform share is stored
/// as a row with recipientUserId = null + label = "Platform". Sum of percents
/// across a deal's splits is enforced at write time to be exactly 100.
model CommissionSplit {
  id              String    @id @default(uuid())
  companyId       String
  company         Company   @relation(fields: [companyId], references: [id])
  dealId          String
  deal            Deal      @relation(fields: [dealId], references: [id])
  recipientUserId String?
  recipient       User?     @relation("CommissionSplitRecipient", fields: [recipientUserId], references: [id])
  label           String
  percent         Decimal   @db.Decimal(5, 2)
  paidAt          DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([dealId])
  @@index([companyId])
  @@index([recipientUserId])
}

model Commission {
  id              String           @id @default(uuid())
  dealId          String           @unique
  deal            Deal             @relation(fields: [dealId], references: [id])
  status          CommissionStatus @default(expected)
  expectedAmount  Decimal          @db.Decimal(12, 2)
  invoicedAmount  Decimal?         @db.Decimal(12, 2)
  collectedAmount Decimal          @default(0) @db.Decimal(12, 2)
  invoicedAt      DateTime?
  collectedAt     DateTime?
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  payments PaymentRecord[]
}

model PaymentRecord {
  id           String        @id @default(uuid())
  commissionId String
  commission   Commission    @relation(fields: [commissionId], references: [id])
  amount       Decimal       @db.Decimal(12, 2)
  status       PaymentStatus @default(pending)
  method       String? // "bank_transfer" | "cash" | "cheque" | ...
  reference    String?
  paidAt       DateTime?
  createdAt    DateTime      @default(now())
}

// =============================================================================
// AUTOMATION + NOTIFICATIONS
// =============================================================================

model AutomationRule {
  id          String                @id @default(uuid())
  companyId   String
  company     Company               @relation(fields: [companyId], references: [id])
  name        String
  triggerType AutomationTriggerType
  triggerKey  String // event name or cron expression
  conditions  Json?
  actions     Json
  active      Boolean               @default(true)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  jobs AutomationJob[]

  @@index([companyId, active])
}

model AutomationJob {
  id        String         @id @default(uuid())
  ruleId    String
  rule      AutomationRule @relation(fields: [ruleId], references: [id])
  status    String // "queued" | "running" | "succeeded" | "failed"
  payload   Json?
  result    Json?
  error     String?
  runAt     DateTime
  startedAt DateTime?
  endedAt   DateTime?
  createdAt DateTime       @default(now())

  @@index([ruleId, status])
  @@index([runAt])
}

model Notification {
  id        String           @id @default(uuid())
  companyId String
  company   Company          @relation(fields: [companyId], references: [id])
  userId    String?
  user      User?            @relation(fields: [userId], references: [id])
  kind      NotificationKind @default(info)
  title     String
  body      String?
  link      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([companyId, userId, readAt])
}

// =============================================================================
// AI SUGGESTIONS + TRAINING EXAMPLES (human-in-the-loop)
// =============================================================================

enum SuggestionStatus {
  pending
  approved
  edited
  cancelled
  failed
  expired
}

model Suggestion {
  id               String               @id @default(uuid())
  companyId        String
  company          Company              @relation(fields: [companyId], references: [id])
  leadId           String
  lead             Lead                 @relation(fields: [leadId], references: [id])
  conversationId   String
  conversation     WhatsAppConversation @relation(fields: [conversationId], references: [id])
  inboundMessageId String?

  state          String // workflow state when generated
  systemPrompt   String? // hash or excerpt for traceability
  suggestedReply String // what the AI proposed
  reasoning      String? // model's internal rationale
  confidence     Float? // 0-1
  stateAfter     String? // suggested next state
  escalate       Boolean @default(false)

  status SuggestionStatus @default(pending)

  finalReply        String? // what was actually sent (may equal suggestion or be edited)
  decidedById       String?
  decidedBy         User?     @relation("SuggestionDecidedBy", fields: [decidedById], references: [id])
  decidedAt         DateTime?
  outboundMessageId String?

  modelId             String
  inputTokens         Int?
  outputTokens        Int?
  cacheReadTokens     Int?
  cacheCreationTokens Int?
  latencyMs           Int?
  errorMessage        String?

  trainingExample TrainingExample? @relation("SuggestionTrainingExample")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, status])
  @@index([leadId])
  @@index([conversationId])
}

model TrainingExample {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  suggestionId String     @unique
  suggestion   Suggestion @relation("SuggestionTrainingExample", fields: [suggestionId], references: [id])

  state           String
  contextSnapshot Json
  aiSuggestion    String // verbatim model output
  operatorEdit    String // operator's corrected version

  enabled Boolean @default(true) // include in few-shot
  pinned  Boolean @default(false) // always include
  notes   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, enabled])
  @@index([companyId, state, enabled])
}
